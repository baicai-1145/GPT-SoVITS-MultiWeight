# Copy this file to `configs/mps/default.env` for local use.
# This example is safe to commit because it avoids machine-specific absolute paths.

export GPT_SOVITS_CONDA_ENV="${GPT_SOVITS_CONDA_ENV:-GPTSoVits}"

# Change this to your local Conda/Miniconda/Mambaforge installation root.
# Example:
#   /opt/conda
#   /root/miniconda3
#   /home/yourname/miniconda3
export GPT_SOVITS_CONDA_BASE="${GPT_SOVITS_CONDA_BASE:-/path/to/miniconda3}"

# Select which GPU is visible to the MPS daemon and worker processes.
export GPT_SOVITS_CUDA_VISIBLE_DEVICES="${GPT_SOVITS_CUDA_VISIBLE_DEVICES:-0}"

# Runtime directories. Defaults under /tmp are usually portable on Linux.
export GPT_SOVITS_MPS_PIPE_DIRECTORY="${GPT_SOVITS_MPS_PIPE_DIRECTORY:-/tmp/gpt-sovits-mps-pipe}"
export GPT_SOVITS_MPS_LOG_DIRECTORY="${GPT_SOVITS_MPS_LOG_DIRECTORY:-/tmp/gpt-sovits-mps-log}"
export GPT_SOVITS_RUNTIME_DIR="${GPT_SOVITS_RUNTIME_DIR:-/tmp/gpt-sovits-runtime}"
export GPT_SOVITS_LOG_DIR="${GPT_SOVITS_LOG_DIR:-/tmp/gpt-sovits-logs}"
